<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DebrisFlowDashboard_Alprog.MainDashboardPage"
             Title="Dashboard EWS Debris Flow"
             BackgroundColor="#1E293B">

    <Grid ColumnDefinitions="6*, 4*" RowDefinitions="Auto, *" Padding="20" RowSpacing="20" ColumnSpacing="20">

        <VerticalStackLayout Grid.Row="0" Grid.ColumnSpan="2" Spacing="15">
            <Label Text="SISTEM PEMANTAUAN DEBRIS FLOW TERPADU" FontSize="24" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />

            <SearchBar x:Name="SearchBarNLP" 
                       Placeholder="Ketik perintah (misal: cek hujan...)" 
                       SearchButtonPressed="OnSearchButtonPressed" 
                       BackgroundColor="White" 
                       TextColor="Black" 
                       HorizontalOptions="Fill" />
        </VerticalStackLayout>


        <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="15">
            <Label Text="Live Feed: Kamera Hilir (Pos Pantau A)" TextColor="#94A3B8" FontAttributes="Bold" />

            <Frame BackgroundColor="Black" HeightRequest="350" CornerRadius="10" Padding="0" IsClippedToBounds="True">
                <Image x:Name="CctvPreview" Aspect="AspectFill" />
            </Frame>

            <Button Text="[1] Ambil Sampel Foto Hilir" BackgroundColor="#2563EB" TextColor="White" FontAttributes="Bold" Clicked="OnCaptureRiverClicked" />

            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Button Text="Normal (RGB)" BackgroundColor="#475569" TextColor="White" Clicked="OnNormalFilterClicked" />
                <Button Text="Grayscale" BackgroundColor="#475569" TextColor="White" Clicked="OnGrayscaleFilterClicked" />
                <Button Text="Edge Detection" BackgroundColor="#475569" TextColor="White" Clicked="OnEdgeFilterClicked" />
            </HorizontalStackLayout>
        </VerticalStackLayout>


        <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="20">

            <Frame BackgroundColor="#B91C1C" CornerRadius="8" Padding="15">
                <VerticalStackLayout>
                    <Label Text="STATUS LOGIKA FUZZY" TextColor="#FECACA" FontSize="12" FontAttributes="Bold" />
                    <Label x:Name="LabelStatus" Text="AWAS (SIAGA 1)" TextColor="White" FontSize="20" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="#334155" CornerRadius="8" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="DATA TELEMETRI (NODE HULU)" TextColor="White" FontAttributes="Bold" />
                    <Label Text="Kelembapan Tanah (Soil Probe):" TextColor="#94A3B8" />
                    <Label x:Name="LabelMoisture" Text="85.4 % (Saturasi Tinggi)" TextColor="#34D399" FontSize="18" FontAttributes="Bold" />
                    <Label Text="Intensitas Curah Hujan:" TextColor="#94A3B8" />
                    <Label x:Name="LabelRainfall" Text="120 mm/jam" TextColor="#FBBF24" FontSize="18" FontAttributes="Bold" />
                    <Label Text="Koneksi Jaringan:" TextColor="#94A3B8" />
                    <Label Text="LoRaWAN (Gateway 1) - Stabil" TextColor="#60A5FA" FontSize="14" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>

            <Frame x:Name="PanelSuperAdmin" BackgroundColor="#1E293B" BorderColor="#F59E0B" CornerRadius="8" Padding="15" IsVisible="False">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🛡️ PANEL SUPER ADMIN (BMKG ONLY)" TextColor="#F59E0B" FontAttributes="Bold" FontSize="14"/>
                    <Label Text="Daftar Pengguna Terdaftar di Sistem:" TextColor="#94A3B8" FontSize="12"/>
                    <Label x:Name="LabelDaftarUser" Text="Memuat..." TextColor="White" FontSize="13"/>

                    <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                        <Entry x:Name="EntryHapusUser" Placeholder="Ketik username yg dihapus..." BackgroundColor="White" TextColor="Black" WidthRequest="200" HeightRequest="40" />
                        <Button Text="HAPUS AKUN" BackgroundColor="#DC2626" TextColor="White" FontAttributes="Bold" HeightRequest="40" Clicked="OnHapusUserClicked" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </Grid>
</ContentPage>